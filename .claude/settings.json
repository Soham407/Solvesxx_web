{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "mcp__supabase-mcp-server__list_tables",
      "mcp__supabase-mcp-server__execute_sql",
      "mcp__supabase-mcp-server__search_docs",
      "mcp__supabase-mcp-server__list_migrations",
      "mcp__supabase-mcp-server__get_advisors",
      "mcp__supabase-mcp-server__generate_typescript_types",
      "mcp__supabase-mcp-server__list_edge_functions",
      "mcp__supabase-mcp-server__get_logs",
      "mcp__supabase-mcp-server__get_project_url",
      "mcp__supabase-mcp-server__get_publishable_keys",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "deny": [
      "Write(supabase-types.ts)",
      "Write(src/types/supabase.ts)",
      "Write(docs/reference_schema.sql)"
    ]
  },
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"CONTEXT REMINDER: Always check .ai_context/PHASES.md and .ai_context/CONTEXT.md before writing code. Do not edit auto-generated files like supabase-types.ts directly.\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | findstr /R \"supabase-types\\.ts src\\\\types\\\\supabase\\.ts docs\\\\reference_schema\\.sql\" >nul 2>&1 && echo BLOCKED: This is an auto-generated file. Do not edit directly. && exit 2 || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | findstr /R \"\\.tsx$ \\.ts$ \\.css$ \\.json$\" >nul 2>&1 && npx prettier --write \"$CLAUDE_FILE_PATH\" 2>nul || exit 0"
          }
        ]
      }
    ]
  }
}
